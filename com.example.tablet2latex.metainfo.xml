<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.example.tablet2latex</id>
  
  <name>Tablet2LaTeX</name>
  <summary>Convert handwritten text and formulas to LaTeX</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0</project_license>
  
  <description>
    <p>
      Tablet2LaTeX is a GTK4-based application for converting handwritten text and mathematical formulas to LaTeX code using vision-enabled Large Language Models (LLMs).
    </p>
    <p>Features:</p>
    <ul>
      <li>Draw mathematical expressions and text on a canvas</li>
      <li>Convert handwriting to LaTeX using AI models</li>
      <li>Support for multiple LLM providers (OpenAI, Ollama, LlamaCpp)</li>
      <li>Copy generated LaTeX directly to clipboard</li>
      <li>Dark theme support</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">com.example.tablet2latex.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Main application window with drawing canvas</caption>
    </screenshot>
  </screenshots>
  
  <url type="homepage">https://github.com/VlastimilHudecek/Tablet2LaTeX</url>
  <url type="bugtracker">https://github.com/VlastimilHudecek/Tablet2LaTeX/issues</url>
  
  <content_rating type="oars-1.1" />
  
  <releases>
    <release version="1.0.0" date="2024-02-14">
      <description>
        <p>Initial release with GTK4 interface</p>
        <ul>
          <li>Drawing canvas for handwriting input</li>
          <li>LaTeX conversion using vision LLMs</li>
          <li>Multiple provider support</li>
          <li>Configuration management</li>
        </ul>
      </description>
    </release>
  </releases>
  
  <developer_name>Vlastimil Hudecek</developer_name>
  <update_contact>vlastimil.hudecek@gmail.com</update_contact>
</component>
